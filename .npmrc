# Supply-chain hardening. See .github/workflows/security-audit.yml for CI enforcement.

# Never auto-execute package lifecycle scripts (postinstall, preinstall, prepare,
# etc.) during `npm install` / `npm ci`. This is the primary defense against
# install-time supply-chain worms (e.g. Shai-Hulud), which propagate via these
# hooks. Verified safe for this project: the build does not rely on any package
# install scripts (esbuild/sharp ship platform binaries via optionalDependencies).
ignore-scripts=true

# Surface known vulnerabilities on every install.
audit=true

# Enforce the Node version declared in package.json "engines".
engine-strict=true

# Reduce install noise.
fund=false
